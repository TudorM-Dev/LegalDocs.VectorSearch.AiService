<Window x:Class="LegalDocs.VectorSearch.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LexCopilot AI" Height="600" Width="900"
        Background="#202020" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" CornerRadius="8" Margin="0,0,0,15" Padding="15">
            <ScrollViewer>
                <TextBlock x:Name="ChatHistory" Foreground="#E0E0E0" FontSize="15" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput" Grid.Column="0" Height="45" FontSize="15" 
                     Background="#3E3E42" Foreground="White" BorderBrush="#555" 
                     VerticalContentAlignment="Center" Padding="10,0"/>

            <Button x:Name="SendButton" Grid.Column="1" Content="Send" 
        Width="120" Height="45" Margin="15,0,0,0" 
        Background="#007ACC" Foreground="White" FontSize="15" 
        BorderThickness="0" Click="SendButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>